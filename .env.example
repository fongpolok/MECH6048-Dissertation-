# Copy this file to .env and adjust for your environment.

# Where the Ollama server is reachable.
# - Local install (macOS/Linux, `ollama serve`): http://localhost:11434
# - Docker Compose (see docker-compose.yml):     http://ollama:11434
OLLAMA_HOST=http://localhost:11434

# Overrides config.json's "llm_model" / "embedding_model" without editing the file.
# Useful for swapping models per environment (dev laptop vs. server) or for the
# evaluation harness. Leave unset to use the values in config.json.
# OLLAMA_MODEL=qwen2.5:7b-instruct
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Port the FastAPI backend listens on.
API_PORT=8000

# Origins allowed to call the API (comma-separated). Include the Vite dev server
# and any deployed frontend URL.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
